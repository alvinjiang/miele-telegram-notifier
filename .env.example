# Miele API Credentials
# Get these from https://developer.miele.com/get-involved
MIELE_CLIENT_ID=your_client_id_here
MIELE_CLIENT_SECRET=your_client_secret_here

# Your Miele@home account credentials (same as the Miele app)
MIELE_USERNAME=your_miele_email@example.com
MIELE_PASSWORD=your_miele_password

# Country/locale code for your Miele account
# Examples: en-US, en-GB, de-DE, fr-FR, nl-NL, etc.
MIELE_VG=en-US

# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram group chat ID
# To find this: Add @userinfobot to your group and it will tell you the chat ID
# Group IDs are typically negative numbers like -1001234567890
TELEGRAM_CHAT_ID=-1001234567890

# Polling interval in milliseconds (default: 30000 = 30 seconds)
POLL_INTERVAL_MS=30000
